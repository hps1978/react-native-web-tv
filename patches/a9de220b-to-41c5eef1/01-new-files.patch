+  );
+};
+
+const RestoreFocusTestList = () => {
+  const [randomize, setRandomize] = React.useState(false);
+  const data = React.useMemo(() => generateData(10, randomize), [randomize]);
+  /**
+   * This is a test to make sure that the focus is restored
