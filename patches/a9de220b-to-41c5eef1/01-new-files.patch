+  getStats: function (): Object {
+    return {
+      stallCount,
+      totalStallTime,
+      longestStall,
+      acceptableBusyTime
+    };
+  },
+  reset: function () {
+    infoLog('JSEventLoopWatchdog: reset');
+    totalStallTime = 0;
+    stallCount = 0;
+    longestStall = 0;
+    lastInterval = window.performance.now();
+  },
+  addHandler: function (handler: Handler) {
+    handlers.push(handler);
+  },
+  install: function ({
+    thresholdMS
+  }: {
+    thresholdMS: number
+  }) {
+    acceptableBusyTime = thresholdMS;
+    if (installed) {
+      return;
+    }
