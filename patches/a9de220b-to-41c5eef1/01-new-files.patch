+      item: number,
+      index: number
+    }) => {
+      return (
+        <FocusableBox
+          height={itemHeight}
+          id={item}
+          onFocus={onItemFocused}
+          onPress={onItemPressed}
+          slow={slow}
+          style={styles.mr5}
