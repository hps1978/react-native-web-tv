+    paddingHorizontal: 20,
+    paddingVertical: 6,
+    borderRadius: 10,
+    borderWidth: CARD_BORDER,
+    borderColor: 'rgba(255,255,255,0.2)',
+    backgroundColor: 'transparent',
+    transform: [{ scale: 1 }]
