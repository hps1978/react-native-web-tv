+  },
+  tabLabel: {
+    fontSize: 15,
+    fontWeight: 'bold',
+    letterSpacing: 0.5,
+    textTransform: 'uppercase',
+    textAlign: 'center'
+  },
+  tabLabelDefault: {
+    color: 'rgba(255,255,255,0.85)'
+  },
+  tabLabelSelected: {
+    color: '#333'
+  },
+
+  // --- Content scroll ---
+  contentScroll: {
+    flex: 1,
+    flexDirection: 'column'
+  },
+  contentScrollInner: {
+    flexGrow: 1,
+    paddingBottom: 40
+  },
+
+  // --- Grid ---
+  gridContainer: {
+    minHeight: CARD_HEIGHT,
+    pointerEvents: 'box-none'
+  },
+  grid: {
+    flexDirection: 'row',
+    flexWrap: 'wrap',
+    gap: CARD_GAP,
+    paddingHorizontal: 32,
+    paddingTop: 16,
+    paddingBottom: 24,
+    rowGap: CARD_GAP
+  },
+
+  // --- Card ---
+  cardContainer: {
+    width: CARD_WIDTH,
+    height: CARD_HEIGHT,
+    borderRadius: CARD_RADIUS,
+    borderWidth: CARD_BORDER,
