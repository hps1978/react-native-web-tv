+    paddingBottom: 24,
+    height: '100vh'
+  },
+  rowSection: {
+    paddingHorizontal: 24,
+    paddingTop: 14,
+    paddingBottom: 18,
+    width: '100vw',
+    height: ROW_HEIGHT + ROW_TITLE_HEIGHT + 20
+  },
+  rowTitle: {
+    height: ROW_TITLE_HEIGHT,
+    fontSize: 16,
+    fontWeight: '600',
+    color: '#e2e8f0',
+    marginBottom: 8
+  },
+  rowList: {
+    height: ROW_HEIGHT,
+    width: '100vw'
+  },
+  rowContent: {
+    paddingRight: ITEM_SPACING
+  },
+  card: {
+    width: ITEM_SIZE,
+    marginRight: ITEM_SPACING,
+    borderRadius: 12,
+    backgroundColor: '#0b1220',
+    borderWidth: 1,
+    borderColor: '#1f2a44',
+    overflow: 'hidden'
+  },
+  image: {
+    width: ITEM_SIZE,
+    height: ITEM_SIZE
+  },
+  cardTitle: {
+    height: ITEM_TEXT_HEIGHT,
+    paddingHorizontal: 10,
+    paddingTop: 6,
+    fontSize: 12,
+    color: '#e2e8f0'
+  }
+});
+
+export default RLVFlatListTVScrollExample;
