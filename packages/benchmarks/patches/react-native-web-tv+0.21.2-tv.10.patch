+const GLOBAL_ENABLE_KEY = '__RNW_BENCHMARK_PROFILING__';
+const GLOBAL_API_KEY = '__RNW_BENCHMARK_PROFILE__';
+
+const profileMap = new Map();
+
+function canUseWindow() {
+  return typeof window !== 'undefined';
+}
+
+function isEnabled() {
+  return canUseWindow() && window[GLOBAL_ENABLE_KEY] === true;
+}
+
+function now() {
+  if (typeof performance !== 'undefined' && typeof performance.now === 'function') {
+    return performance.now();
+  }
+  return Date.now();
+}
+
+function record(label, duration) {
+  const existing = profileMap.get(label);
+  if (existing != null) {
+    existing.calls += 1;
+    existing.totalTime += duration;
+    existing.maxTime = Math.max(existing.maxTime, duration);
+    return;
+  }
+
+  profileMap.set(label, {
+    calls: 1,
+    totalTime: duration,
+    maxTime: duration
+  });
+}
+
+function snapshot() {
+  return Array.from(profileMap.entries())
+    .map(([label, entry]) => ({
+      avgTime: entry.calls > 0 ? entry.totalTime / entry.calls : 0,
+      calls: entry.calls,
+      label,
+      maxTime: entry.maxTime,
+      totalTime: entry.totalTime
+    }))
+    .sort((a, b) => b.totalTime - a.totalTime);
+}
+
+function reset() {
+  profileMap.clear();
+}
+
+function snapshotAndReset() {
+  const result = snapshot();
+  reset();
+  return result;
+}
+
+function ensureGlobalApi() {
+  if (!canUseWindow() || window[GLOBAL_API_KEY] != null) {
+    return;
+  }
+
+  window[GLOBAL_API_KEY] = {
+    reset,
+    snapshot,
+    snapshotAndReset
+  };
+}
+
+export function profileStart(label) {
+  if (!isEnabled()) {
+    return null;
+  }
+
+  ensureGlobalApi();
+  return now();
+}
+
+export function profileEnd(label, startTime) {
+  if (startTime == null || !isEnabled()) {
+    return;
+  }
+
+  record(label, now() - startTime);
+}
+
+export function profile(label, callback) {
+  const startTime = profileStart(label);
+  try {
+    return callback();
+  } finally {
+    profileEnd(label, startTime);
+  }
